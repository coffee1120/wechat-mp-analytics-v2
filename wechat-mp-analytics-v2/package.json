    "npm": ">=9.0.0"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "dependencies": {
    "puppeteer-core": "^21.0.0",
    "node-fetch": "^3.3.0",
    "ws": "^8.14.0"
  },
  "config": {
    "puppeteerSkipDownload": true
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "eslint": "^8.50.0",
    "jest-puppeteer": "^9.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
