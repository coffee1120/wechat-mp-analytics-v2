    "test:unit": "jest tests/unit/",
    "test:integration": "jest tests/integration/",
    "test:coverage": "jest --coverage",
    "lint": "eslint references/*.js",
    "check-env": "powershell -ExecutionPolicy Bypass -File scripts/check-env.ps1",
